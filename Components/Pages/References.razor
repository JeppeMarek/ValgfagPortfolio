@page "/References"
@rendermode InteractiveServer
@inject NavigationManager nav
<h3>Kilder</h3>
<MudTable bind-SelectedItem="@selectedReference"
          T="Reference"
          Items="references"
          Breakpoint="Breakpoint.SmAndDown">
    <HeaderContent>
        <MudTh>Titel</MudTh>
        <MudTh Style="max-width: 150px;">URL</MudTh>
        <MudTh>Forfatter</MudTh>
        <MudTh Style="min-width: 300px;">Note</MudTh>
        <MudTh>Emne</MudTh>
    </HeaderContent>
    <RowTemplate Context="reference">
        <MudTd>@reference.Title</MudTd>
        <MudTd>
            <MudTooltip Text="@reference.URL">
                <MudLink Target="blank" Href="@reference.URL">@TruncateUrl(reference.URL, 30)</MudLink>
            </MudTooltip>
        </MudTd>
        <MudTd>@reference.Author</MudTd>
        <MudTd>@reference.Note</MudTd>
        <MudTd>@reference.Subject</MudTd>
        <AuthorizeView>
            <MudTd>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="() => DeleteReferenceAsync(reference)"
                           Size="Size.Small">
                    Slet
                </MudButton>
            </MudTd>
        </AuthorizeView>
    </RowTemplate>
</MudTable>

<AuthorizeView>
    <MudExpansionPanel Text="Tilføj Reference" Class="navbar-expand mt-3 rounded-3">
        <MudForm @ref="form" @bind-Errors="@errors">
            <MudTextField @bind-Value="newReference.URL" Label="URL" Required="true" RequiredError="URL er påkrævet"/>
            <MudTextField @bind-Value="newReference.Title" Label="Titel"/>
            <MudTextField @bind-Value="newReference.Author" Label="Forfatter"/>
            <MudTextField @bind-Value="newReference.Note" Label="Note/vurdering" Lines="4"/>
            <MudTextField @bind-Value="newReference.Subject" Label="Emne"/>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddReference" Class="mt-4">Tilføj
            </MudButton>
        </MudForm>
    </MudExpansionPanel>
</AuthorizeView>


@code {
    [Inject] public IReferenceService ReferenceService { get; set; }
    private List<Reference> references = new();
    private Reference newReference = new();
    private MudForm form;
    private int selectedId;
    private Reference selectedReference;
    private string[] errors = { };
    private bool isValid;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            references = await ReferenceService.GetAllReferencesAsync();
            references = references.OrderBy(r => r.Subject).ToList();
        }
        catch (NullReferenceException e)
        {
            Console.WriteLine(e);
        }
    }

    private async Task AddReference()
    {
        try
        {
            await form.Validate();
            if (form.IsValid)
            {
                isValid = await ReferenceService.CreateReferenceAsync(newReference);
                if (isValid)
                {
                    references = await ReferenceService.GetAllReferencesAsync();
                    newReference = new Reference();
                    await form.ResetAsync();
                    nav.Refresh(true);
                }
            }
        }
        catch (Exception e)
        {
            errors = [e.Message];
        }
    }

    private async Task DeleteReferenceAsync(Reference reference)
    {
        await ReferenceService.DeleteReferenceAsync(reference);
        references = await ReferenceService.GetAllReferencesAsync();
        nav.Refresh(true);
    }

    private string TruncateUrl(string url, int maxLength)
    {
        if (string.IsNullOrEmpty(url))
            return url;
        
        return url.Length > maxLength ? url.Substring(0, maxLength) + "..." : url;
    }

}